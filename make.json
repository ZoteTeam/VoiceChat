{
	"$schema": "../schemas/make.schema.json",
	"info": {
		"name": "VoiceChat",
		"description": "Voice chat mod",
		"author": "Reider745",
		"version": "1.0",
		"icon": "mod_icon.png",
		"clientOnly": true
	},
	"api": "CoreEngine",
	"gradle": {
		"build": "build"
	},
	"java": {
		"configurable": true
	},
	"declarations": [
		"declarations/android.d.ts"
	],
	"resources": [
		{
			"path": "assets/gui",
			"type": "gui"
		}
	],
	"sources": [
		{
			"source": "launcher.js",
			"type": "launcher",
			"language": "javascript"
		},
		{
			"source": "dev",
			"type": "main",
			"target": "main.js"
		},
		{
			"source": "preloader.js",
			"type": "preloader",
			"language": "javascript"
		}
	],
	"compile": [
		{
			"source": "native/*",
			"type": "native"
		},
		{
			"source": "java/*",
			"type": "java"
		}
	],
	"native": {
		"options": [],
		"configurations": {
			"arm64": {
				"options": ["-std=c99", "-DARM64=1"]
			}
		}
	},
	"additional": [
		{
			"source": "assets/weights_blob_small.bin",
			"targetDir": "."
		}
	]
}
