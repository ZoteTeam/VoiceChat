{
	"$schema": "../schemas/make.schema.json",
	"info": {
		"name": "VoiceChat",
		"description": "Voice chat mod",
		"author": "Reider745",
		"version": "1.0",
		"icon": "mod_icon.png",
		"clientOnly": true
	},
	"api": "CoreEngine",
	"gradle": {
		"build": "build"
	},
	"java": {
		"configurable": true
	},
	"declarations": [
		"declarations/android.d.ts"
	],
	"resources": [],
	"sources": [
		{
			"source": "launcher.js",
